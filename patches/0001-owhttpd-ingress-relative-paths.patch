# owhttpd: convert absolute hrefs to relative paths for HA ingress
#
# Home Assistant ingress proxy rewrites URLs, so owhttpd links must use
# relative paths instead of absolute ones. Without this, navigation within
# the owhttpd web UI is broken when accessed through HA ingress.
#
# Applied against OWFS v3.2p4 (commit c68deb1)

diff --git a/module/owhttpd/src/c/owhttpd_dir.c b/module/owhttpd/src/c/owhttpd_dir.c
index 5c5074d..8204688 100644
--- a/module/owhttpd/src/c/owhttpd_dir.c
+++ b/module/owhttpd/src/c/owhttpd_dir.c
@@ -59,7 +59,7 @@ static void ShowDirCallback(void *v, const struct parsedname *pn_entry)
 	}
 
 	fprintf(out,
-			"<TR><TD><A HREF='%s'><CODE><B><BIG>%s</BIG></B></CODE></A></TD><TD>%s</TD><TD>%s</TD></TR>", escaped_path==NULL ? pn_entry->path : escaped_path, FS_DirName(pn_entry), nam,
+			"<TR><TD><A HREF='.%s'><CODE><B><BIG>%s</BIG></B></CODE></A></TD><TD>%s</TD><TD>%s</TD></TR>", escaped_path==NULL ? pn_entry->path : escaped_path, FS_DirName(pn_entry), nam,
 			typ);
 
 	if ( escaped_path ) {
@@ -101,12 +101,12 @@ void ShowDir(struct OutputControl * oc, struct parsedname * pn)
 
 	if (b != 1) {
 		char * escaped_path = httpescape( pn->path ) ;
-		fprintf(out, "<TR><TD><A HREF='%.*s'><CODE><B><BIG>up</BIG></B></CODE></A></TD><TD>higher level</TD><TD>directory</TD></TR>", b, escaped_path==NULL ? pn->path : escaped_path );
+		fprintf(out, "<TR><TD><A HREF='././././'><CODE><B><BIG>up</BIG></B></CODE></A></TD><TD>higher level</TD><TD>directory</TD></TR>", b, escaped_path==NULL ? pn->path : escaped_path );
 		if ( escaped_path ) {
 			owfree( escaped_path ) ;
 		}
 	} else {
-		fprintf(out, "<TR><TD><A HREF='/'><CODE><B><BIG>top</BIG></B></CODE></A></TD><TD>highest level</TD><TD>directory</TD></TR>");
+		fprintf(out, "<TR><TD><A HREF='././././'><CODE><B><BIG>top</BIG></B></CODE></A></TD><TD>highest level</TD><TD>directory</TD></TR>");
 	}
 
 	FS_dir(ShowDirCallback, oc, pn);
